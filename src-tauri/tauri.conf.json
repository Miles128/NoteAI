{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "NoteAI",
  "version": "0.1.0",
  "identifier": "com.noteai.app",
  "build": {
    "frontendDist": "../webui",
    "beforeDevCommand": "npm run build:tiptap",
    "beforeBuildCommand": "npm run build:tiptap"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "NoteAI",
        "width": 1380,
        "height": 900,
        "minWidth": 980,
        "minHeight": 700,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self'; connect-src 'self' tauri://localhost ipc://localhost https://ipc.localhost; worker-src 'self' blob:; frame-src 'none'; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../python/**/*"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
